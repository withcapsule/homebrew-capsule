class Capsule < Formula
  desc "CLI for the Capsule server"
  homepage "https://github.com/seanathan10/Capsule"
  version "0.1.0"
  license "MIT"

  on_macos do
    on_arm do
      url "https://github.com/seanathan10/Capsule/releases/download/v#{version}/capsule-aarch64-apple-darwin.tar.gz"
      sha256 "REPLACE_WITH_SHA256_FOR_MACOS_AARCH64"
    end
    on_intel do
      url "https://github.com/seanathan10/Capsule/releases/download/v#{version}/capsule-x86_64-apple-darwin.tar.gz"
      sha256 "REPLACE_WITH_SHA256_FOR_MACOS_X86_64"
    end
  end

  on_linux do
    on_arm do
      url "https://github.com/seanathan10/Capsule/releases/download/v#{version}/capsule-aarch64-unknown-linux-gnu.tar.gz"
      sha256 "REPLACE_WITH_SHA256_FOR_LINUX_AARCH64"
    end
    on_intel do
      url "https://github.com/seanathan10/Capsule/releases/download/v#{version}/capsule-x86_64-unknown-linux-gnu.tar.gz"
      sha256 "REPLACE_WITH_SHA256_FOR_LINUX_X86_64"
    end
  end

  def install
    bin.install "capsule"
  end

  def post_install
    generate_completions_from_executable(bin/"capsule", "completions")
  end

  test do
    system bin/"capsule", "--version"
  end
end
